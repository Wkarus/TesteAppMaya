<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F6"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/screen_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="◀"
            android:textColor="@color/text_on_primary"
            android:textSize="20sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/agendar_consulta_upper"
            android:textAlignment="center"
            android:textColor="@color/text_on_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="28dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card do calendário -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Controles de navegação do mês -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnPrevMonth"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/mes_anterior"
                        android:src="@android:drawable/ic_media_previous"
                        app:tint="@android:color/black" />

                    <TextView
                        android:id="@+id/tvMonth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:text="Sep"
                        android:textColor="@android:color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvYear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2025"
                        android:textColor="@android:color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnNextMonth"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/proximo_mes"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="@android:color/black" />
                </LinearLayout>

                <!-- Cabeçalho dos dias da semana -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Su"
                        android:textColor="#909090" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Mo"
                        android:textColor="#909090" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Tu"
                        android:textColor="#909090" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="We"
                        android:textColor="#909090" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Th"
                        android:textColor="#909090" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Fr"
                        android:textColor="#909090" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Sa"
                        android:textColor="#909090" />
                </LinearLayout>

                <!-- Calendário Kizitonwose -->
                <com.kizitonwose.calendar.view.CalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cv_dayViewResource="@layout/calendar_day_layout" />
            </LinearLayout>

            <!-- Botão da data selecionada -->
            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="172dp"
                android:layout_height="46dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_chip_blue"
                android:gravity="center"
                android:text="Qua, 22/04"
                android:textColor="@color/text_on_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Grade de horários - primeira linha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnTime0900"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_blue"
                    android:text="9:00"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnTime1000"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_blue"
                    android:text="10:00"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnTime1100"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_blue"
                    android:text="11:00"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Grade de horários - segunda linha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnTime0930"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_blue"
                    android:text="9:30"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnTime1030"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_blue"
                    android:text="10:30"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnTime1130"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_blue"
                    android:text="11:30"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnConfirmarAgendamento"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_green"
                android:enabled="false"
                android:text="@string/confirmar_agendamento"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <!-- Preview do rodapé no editor -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:visibility="gone"
        app:itemIconTint="@null"
        app:itemTextColor="@color/primary_dark"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        tools:selectedItemId="@id/nav_schedule"
        tools:visibility="visible" />

</LinearLayout>
