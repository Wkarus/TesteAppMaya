<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp">

        <ImageView
            android:layout_width="260dp"
            android:layout_height="74dp"
            android:layout_marginTop="104dp"
            android:layout_marginBottom="48dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/logo_maya_1" />

        <TextView
            android:layout_width="245dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/label_usuario"
            android:textColor="@color/text_on_primary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etUsuario"
            android:layout_width="245dp"
            android:layout_height="38dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_input"
            android:textColor="@color/black"
            android:elevation="4dp"
            android:inputType="text"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="245dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/label_senha"
            android:textColor="@color/text_on_primary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etSenha"
            android:layout_width="245dp"
            android:layout_height="38dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/black"
            android:background="@drawable/bg_input"
            android:elevation="4dp"
            android:inputType="textPassword"
            android:paddingHorizontal="12dp" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="140dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_green"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/btn_login"
            android:textAllCaps="false"
            android:textColor="@color/text_on_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCadastro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/nao_tem_cadastro"
            android:textColor="@color/text_on_primary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnVisitante"
            android:layout_width="160dp"
            android:layout_height="42dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/btn_visitante"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>